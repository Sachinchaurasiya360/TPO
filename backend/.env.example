# ==================== DATABASE ====================
# Neon PostgreSQL Database URL
# Sign up at https://console.neon.tech
# Copy your connection string and paste it below
# Format: postgresql://username:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.neon.tech/dbname?sslmode=require

# ==================== SERVER ====================
PORT=3000

# Node environment (development or production)
NODE_ENV=development

# Log level (optional)
LOG_LEVEL=info

# ==================== FRONTEND ====================
# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:5173

# ==================== JWT AUTHENTICATION ====================
# JWT secret key - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret

# JWT token expiration time
JWT_EXPIRES_IN=7d

# Cookie security settings (set to "true" in production with HTTPS)
COOKIE_SECURE=false

# ==================== EMAIL SERVICE (RESEND) ====================
# Get your API key from https://resend.com
RESEND_API_KEY=re_your_api_key

# Email sender address (must be verified in Resend dashboard)
RESEND_FROM_EMAIL=TPO Vishwaniketan <noreply@yourdomain.com>

# ==================== CLOUDINARY (IMAGE/FILE UPLOAD) ====================
# Get credentials from https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name

CLOUDINARY_API_KEY=your_api_key

CLOUDINARY_API_SECRET=your_api_secret
